[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Target = linux
Target = linux-cachyos
Target = linux-zen
Target = linux-hardened
Target = linux-lts
Target = linux-headers
Target = linux-cachyos-headers
Target = linux-zen-headers
Target = linux-hardened-headers
Target = linux-lts-headers

[Action]
Description = Patching btusb module for CSR8510 A10 (10d7:b012) clone support
When = PostTransaction
Exec = /usr/local/bin/patch-btusb-csr8510.sh
Depends = clang
