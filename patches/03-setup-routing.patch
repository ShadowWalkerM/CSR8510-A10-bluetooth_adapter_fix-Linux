--- a/drivers/bluetooth/btusb.c
+++ b/drivers/bluetooth/btusb.c
@@ ... @@ static int btusb_probe(struct usb_device *udev, const struct usb_device_id *id)
 
 		/* Fake CSR devices with broken commands */
-		if (le16_to_cpu(udev->descriptor.idVendor)  == 0x0a12 &&
-		    le16_to_cpu(udev->descriptor.idProduct) == 0x0001)
+		if ((le16_to_cpu(udev->descriptor.idVendor)  == 0x0a12 &&
+		     le16_to_cpu(udev->descriptor.idProduct) == 0x0001) ||
+		    (le16_to_cpu(udev->descriptor.idVendor)  == 0x10d7 &&
+		     le16_to_cpu(udev->descriptor.idProduct) == 0xb012))
 			hdev->setup = btusb_setup_csr;
 	}

Routes 10d7:b012 through btusb_setup_csr() which:
- Detects the clone via manufacturer/version checks
- Applies broken-command workarounds
- Force-suspends/resumes to activate the bulk RX endpoint
